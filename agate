#!/bin/bash

REPO="https://raw.githubusercontent.com/COLD1224/AgateRepository/main/downloads"

case "$1" in
    help)
        echo "Agate Package Manager"

        echo "commands:"
        echo "inst (installs APkgs)"
        echo "gtrd (removes APkgs)"
        echo "help (shows commands again)"
        echo "list (shows APkg names and their download acronyms)"
	echo "apt (use apt commands (currently only install and update)"
	echo "-ver (check the version of the agate you installed)"
echo "made by Gemstone!"
        ;;
    inst)
	if [ -z "$2" ]; then
    		echo "Error: no package specified."
    		echo "Usage: agate inst <package>"
    		exit 1
	fi
        wget -4 -q -O packages.txt "https://raw.githubusercontent.com/COLD1224/AgateRepository/main/packages.txt"

	if [ $? -ne 0 ]; then
    		echo "Error: failed to download repository."
   		exit 1
	fi

	found=false

        while IFS='|' read -r id name path;
        do
           if [[ "$id" == "$2" ]]; then
		found=true
                echo "Found APkg: $name"
                echo "Path: $path"
                sleep 1
                echo "installing.."
                url="$REPO/$path"
                filename=$(basename "$path")

                INSTALL="$HOME/.local/bin"

		mkdir -p "$INSTALL"

		if ! wget -4 -q -O "$INSTALL/$filename" "$url"; then
    			echo "Error: failed to download $name."
    			exit 1
		fi

	chmod +x "$INSTALL/$filename"

	echo "installed $name!"

           fi
        done < packages.txt
	rm packages.txt
	if [ "$found" = false ]; then
    echo "Error: package '$2' not found."
    exit 1
fi
        ;;
    gtrd)
    if [ -z "$2" ]; then
        echo "Error: no package specified."
        echo "Usage: agate gtrd <package>"
        exit 1
    fi

    if ! wget -4 -q -O packages.txt "https://raw.githubusercontent.com/COLD1224/AgateRepository/main/packages.txt"; then
        echo "Error: failed to download repository."
        exit 1
    fi

    found=false

    while IFS='|' read -r idrm name path;
    do
        if [[ "$idrm" == "$2" ]]; then
            found=true
            echo "Found APkg: $name"
            echo "Path: $path"
            echo "removing.."

            filename=$(basename "$path")

            rm "$HOME/.local/bin/$filename"

            sleep 2

            echo "removed $filename"
        fi
    done < packages.txt

    rm packages.txt

    if [ "$found" = false ]; then
        echo "Error: package '$2' not found."
        exit 1
    fi
    ;;
    -ver)
	echo "Agate Version: v1.0.5 (Bugfix)"
	;;
    apt)
	echo "what do you want to do with apt?"

	read aptanswer

	if [[ "$aptanswer" == "install" ]]; then
		echo "what do you want to install with apt?"
		read packageanswer
		sudo apt install "$packageanswer"

	elif [[ "$aptanswer" == "update" ]]; then
		sudo apt update
    
    elif [[ "$aptanswer" == "upgrade" ]]; then
        sudo apt upgrade

    elif [[ "$aptanswer" == "remove" ]]; then
        echo "what do you want to remove with apt?"
        read packageanswer
        sudo apt remove "$packageanswer"

    elif [[ "$aptanswer" == "purge" ]]; then
        echo "what do you want to purge with apt?"
        read packageanswer
        sudo apt purge "$packageanswer"

    elif [[ "$aptanswer" == "autoremove" ]]; then
        sudo apt autoremove

    elif [[ "$aptanswer" == "search" ]]; then
        echo "what do you want to search with apt?"
        read packageanswer
        sudo apt search "$packageanswer"

    elif [[ "$aptanswer" == "show" ]]; then
        echo "what do you want to show with apt?"
        read packageanswer
        sudo apt show "$packageanswer"

    elif [[ "$aptanswer" == "list" ]]; then
        echo "what do you want to list with apt?"
        read packageanswer
        sudo apt list "$packageanswer"
	else
		echo "unknown apt command."
	fi
	;;
    list)
        echo "APkg list:"
        echo "azureland al"
        echo "DevTooz dtz"
        echo "FastStart fs"
        ;;
    *)
        echo "Unknown command. check 'agate help' maybe you misspelled it."
        ;;
esac
